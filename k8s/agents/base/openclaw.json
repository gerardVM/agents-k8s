{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "enabled": false
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "models": {
        "deepseek/deepseek-chat": {
          "alias": "DeepSeek"
        },
        "openai/gpt-mini": {
          "alias": "GPT-Mini"
        }
      },
      "model": {
        "primary": "deepseek/deepseek-chat"
      }
    },
    "list": [
      {
        "id": "default",
        "name": "OpenClaw Assistant",
        "workspace": "~/.openclaw/workspace"
      }
    ]
  },
  "cron": {
    "enabled": false
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 131072,
            "maxTokens": 8192,
            "cost": {
              "input": 0.28,
              "output": 0.42,
              "cacheRead": 0.028,
              "cacheWrite": 0
            },
            "compat": {
              "supportsUsageInStreaming": true
            },
            "api": "openai-completions"
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek Reasoner",
            "reasoning": true,
            "input": [
              "text"
            ],
            "contextWindow": 131072,
            "maxTokens": 8192,
            "cost": {
              "input": 0.56,
              "output": 2.2,
              "cacheRead": 0.14,
              "cacheWrite": 0
            },
            "compat": {
              "supportsUsageInStreaming": true
            },
            "api": "openai-completions"
          }
        ]
      },
      "openai": {
        "baseUrl": "https://api.openai.com",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-mini",
            "name": "GPT-Mini",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 32768,
            "maxTokens": 4096,
            "compat": {
              "supportsUsageInStreaming": true
            },
            "api": "openai-completions"
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": [
        "YOUR_TELEGRAM_USER_ID"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "apiRoot": "http://telegram-api-service:8080"
    }
  }
}
